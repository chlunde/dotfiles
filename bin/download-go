#!/bin/bash
v=1.26.1
hash=031f088e5d955bab8657ede27ad4e3bc5b7c1ba281f05f245bcc304f327c987a

if [[ "$(go version 2>/dev/null)" == "go version go$v "* ]]; then
	echo "Already updated"
	exit 0
fi

mkdir -p ~/Downloads/
declare -r binary=~/Downloads/go$v.linux-amd64.tar.gz
curl -L -o "$binary" https://go.dev/dl/go$v.linux-amd64.tar.gz

found="$(sha256sum $binary | cut -d ' ' -f1)"

if [[ $found != "$hash" ]]; then
	echo "Checksum mismatch: ${found}"
	exit 1
fi

mkdir -p ~/opt
rm -Rf ~/opt/go
tar -C ~/opt -xzf $binary
